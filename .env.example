PORT=4000
NODE_ENV=development

# MongoDB connection string
# For local Mongo: mongodb://localhost:27017/seu
# For Atlas:       mongodb+srv://<user>:<pass>@<cluster>/seu?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/seu

# CORS origin for the Next.js frontend (comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000

# API global prefix
API_PREFIX=api
